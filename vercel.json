{
  "version": 2,
  "builds": [
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/chat.js"
    },
    { 
        "src": "/", 
        "dest": "client/build/index.html" },
    {
      "src": "/(.*)",
      "dest": "client/build/$1"
    }
  ]
}